---
# Only diagnose our own sources, never subprojects/ (cglm, libsixel, ...).
HeaderFilterRegex: 'src/.*'

Checks: >
  clang-analyzer-*,
  bugprone-*,
  performance-*,
  readability-*,
  -readability-magic-numbers,
  -readability-identifier-length,
  -readability-duplicate-include

# readability-duplicate-include is disabled: it treats the libsixel system
# header <sixel.h> as a duplicate of the local "sixel.h" (same filename) and
# replaces it with <stddef.h>, which breaks the build.

WarningsAsErrors: ''
FormatStyle: file
...
